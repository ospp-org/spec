{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ospp-standard.org/schemas/v1/mqtt/firmware-status-notification.schema.json",
  "title": "FirmwareStatusNotification",
  "description": "Notification from the station reporting firmware update progress.",
  "type": "object",
  "required": ["status", "firmwareVersion"],
  "additionalProperties": false,
  "properties": {
    "status": {
      "type": "string",
      "enum": ["Downloading", "Downloaded", "Installing", "Installed", "Failed"]
    },
    "firmwareVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "maxLength": 32
    },
    "progress": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "errorText": {
      "type": "string",
      "maxLength": 128
    }
  }
}
