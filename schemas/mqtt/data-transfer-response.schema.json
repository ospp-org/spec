{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ospp-standard.org/schemas/v1/mqtt/data-transfer-response.schema.json",
  "title": "DataTransferResponse",
  "description": "Response to a DataTransfer request indicating acceptance or rejection.",
  "type": "object",
  "required": ["status"],
  "additionalProperties": false,
  "properties": {
    "status": {
      "type": "string",
      "enum": ["Accepted", "Rejected", "UnknownVendor", "UnknownData"]
    },
    "data": {
      "type": "object",
      "description": "Vendor-defined response payload."
    }
  }
}
