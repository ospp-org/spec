{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ospp-standard.org/schemas/v1/ble/available-services.schema.json",
  "title": "AvailableServices",
  "description": "Service catalog available at the station, read via BLE characteristic FFF2 (Read). Lists all bays and their available services with pricing.",
  "type": "object",
  "required": [
    "catalogVersion",
    "bays"
  ],
  "additionalProperties": false,
  "properties": {
    "catalogVersion": {
      "type": "string",
      "minLength": 1,
      "maxLength": 32,
      "description": "Version identifier of the service catalog"
    },
    "bays": {
      "type": "array",
      "minItems": 1,
      "description": "List of service bays and their available services",
      "items": {
        "type": "object",
        "required": [
          "bayId",
          "bayNumber",
          "status",
          "services"
        ],
        "additionalProperties": false,
        "properties": {
          "bayId": {
            "$ref": "../common/bay-id.schema.json"
          },
          "bayNumber": {
            "type": "integer",
            "minimum": 1,
            "description": "Human-readable bay number"
          },
          "status": {
            "$ref": "../common/bay-status.schema.json"
          },
          "services": {
            "type": "array",
            "minItems": 1,
            "description": "List of services offered in this bay",
            "items": {
              "type": "object",
              "required": [
                "serviceId",
                "serviceName",
                "pricingType",
                "available"
              ],
              "additionalProperties": false,
              "properties": {
                "serviceId": {
                  "$ref": "../common/service-id.schema.json"
                },
                "serviceName": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 128,
                  "description": "Display name of the service"
                },
                "pricingType": {
                  "type": "string",
                  "enum": ["PerMinute", "Fixed"],
                  "description": "How this service is priced"
                },
                "priceCreditsPerMinute": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Price in credits per minute for PerMinute services"
                },
                "priceCreditsFixed": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Fixed price in credits for Fixed-price services"
                },
                "priceLocalPerMinute": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Price in local-currency minor units per minute for PerMinute services"
                },
                "priceLocalFixed": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Fixed price in local-currency minor units for Fixed-price services"
                },
                "available": {
                  "type": "boolean",
                  "description": "Whether this service is currently available for use"
                }
              }
            }
          }
        }
      }
    }
  }
}
