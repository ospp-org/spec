{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ospp-standard.org/schemas/v1/common/reservation-id.schema.json",
  "title": "Reservation ID",
  "description": "Unique identifier for a bay reservation, prefixed with rsv_",
  "type": "string",
  "pattern": "^rsv_[a-f0-9]{8,}$",
  "minLength": 12,
  "maxLength": 64
}
