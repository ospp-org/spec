{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ospp-standard.org/schemas/v1/common/bay-id.schema.json",
  "title": "Bay ID",
  "description": "Unique identifier for a service bay within a station, prefixed with bay_",
  "type": "string",
  "pattern": "^bay_[a-f0-9]{8,}$",
  "minLength": 12,
  "maxLength": 64
}
