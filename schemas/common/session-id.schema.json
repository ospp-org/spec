{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ospp-standard.org/schemas/v1/common/session-id.schema.json",
  "title": "Session ID",
  "description": "Unique identifier for a service session, prefixed with sess_",
  "type": "string",
  "pattern": "^sess_[a-f0-9]{8,}$",
  "minLength": 13,
  "maxLength": 64
}
