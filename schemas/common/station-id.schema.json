{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ospp-standard.org/schemas/v1/common/station-id.schema.json",
  "title": "Station ID",
  "description": "Unique identifier for a self-service station, prefixed with stn_",
  "type": "string",
  "pattern": "^stn_[a-f0-9]{8,}$",
  "minLength": 12,
  "maxLength": 64
}
